# KeymouseGo - excluded from git (too large, ~57MB)
KeymouseGo_v5_2_1-win.exe

# Python cache
__pycache__/
*.pyc

# Logs
logs/
*.log

# PyInstaller build artifacts (rebuildable, never commit)
build/
dist/

# Runtime / activation cache (machine-specific)
last_verify.dat

# License key (user-specific)
license.key

# IDE
.vscode/
.idea/
*.swp
*.swo

# WowOpenBox is a separate submodule/repo
WowOpenBox/

# License server node_modules
license-server/node_modules/
